# adw-gates.conf — per-project override of the ADW gate commands.
# Copy to the target project root and adjust. Any gate not listed here falls
# back to stack autodetection (see .claude/hooks/adw-detect.sh).
# Format: <gate>=<shell command>, run from the project root, exit 0 = pass.
lint=uvx ruff check .
format=uvx ruff format --check .
test=uv run pytest -x -q
# To make the lint gate also enforce docstrings (pydocstyle, Google style),
# extend the lint command or configure it in the project's pyproject.toml:
#   lint=uvx ruff check . --extend-select D --config 'lint.pydocstyle.convention="google"'
